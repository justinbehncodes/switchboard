{
  "manifest_version": 3,
  "name": "Switchboard Companion",
  "version": "1.0",
  "description": "Sends links that belong in another browser profile to Switchboard.",
  "key": "",
  "background": { "service_worker": "sw.js" },
  "permissions": ["nativeMessaging", "tabs", "webNavigation", "identity", "identity.email"],
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
